<?xml version="1.0" encoding="UTF-8"?>
<!--
  로깅 구성. 두 가지를 한다:
  1) 콘솔을 구조화 JSON(ECS)으로 출력한다.
     Boot 기본 base.xml은 "평문" console-appender를 물고 오므로 쓰지 않고, defaults.xml(공통 속성/변환기)
     + structured-console-appender.xml(StructuredLogEncoder)로 직접 조립한다. 포맷은 application.yml의
     `logging.structured.format.console: ecs` → CONSOLE_LOG_STRUCTURED_FORMAT 로 전달된다.
     Micrometer Tracing이 MDC에 넣는 trace.id/span.id가 ECS 필드로 함께 실려 로그↔트레이스 상관이 가능하다.
  2) test 프로필이 아닐 때만 OpenTelemetry appender를 정의·부착해 로그를 OTLP로 내보낸다.
     이 appender는 logback 로그를 OTel LogRecord로 변환하고(활성 span의 trace_id/span_id를 자동 첨부),
     Boot가 구성한 OTLP log exporter(application.yml의 management.opentelemetry.logging.export.otlp.*)가
     이를 Grafana Alloy(:4318)로 push한다 → Alloy가 Grafana Cloud(Loki)로 전달. 즉 metrics/logs/traces가 모두 OTLP 단일 경로다.
     (test 프로필에선 appender를 아예 정의하지 않아, Alloy가 없는 테스트/최소 실행에서 연결 시도가 없다.)

  주의: Boot는 이 appender를 logback에 자동 부착하지 않는다. 기동 시 OpenTelemetryAppender.install(openTelemetry)로
  실제 OpenTelemetry 인스턴스를 주입해야 그 전까지 버퍼링된 로그가 흘러간다 → config/OpenTelemetryLogbackInstaller.
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/structured-console-appender.xml"/>

    <springProfile name="!test">
        <appender name="OTEL" class="io.opentelemetry.instrumentation.logback.appender.v1_0.OpenTelemetryAppender">
            <!-- MDC 항목(있다면)도 로그 속성으로 함께 싣는다. trace_id/span_id는 appender가 활성 컨텍스트에서 자동 첨부. -->
            <captureMdcAttributes>*</captureMdcAttributes>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="OTEL"/>
        </root>
    </springProfile>

    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
